{
  "enabled": false,
  "interval_seconds": 90,
  "cooldown_seconds": 60,
  "max_reply_chars": 900,
  "allowed_actions": ["reply", "status", "rollup", "note", "tail"],
  "operator_only_shell": true,
  "tail_allowlist": [
    "logs/main.log",
    "logs/error.log",
    "logs/chat_history.log",
    "reports/status.txt",
    "reports/rollup.txt",
    "reports/last_reply.txt"
  ]
}
